// WaitPlay Database Schema
// B2B SaaS Gamification Platform for Restaurant Waiting Management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model - Customer Information
model User {
  id            String     @id @default(uuid())
  kakaoId       String?    @unique @map("kakao_id")
  naverId       String?    @unique @map("naver_id")
  nickname      String
  profileImage  String?    @map("profile_image")
  createdAt     DateTime   @default(now()) @map("created_at")
  
  // Relations
  gameLogs      GameLog[]
  coupons       Coupon[]
  favorites     Favorite[]
  
  @@map("users")
}

// Store Model - Restaurant/Store Information
model Store {
  id                 String   @id @default(uuid())
  ownerId            String   @map("owner_id")
  name               String
  logoUrl            String?  @map("logo_url")
  themeColor         String?  @map("theme_color") // Hex color code
  subscriptionStatus SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  qrCodeUrl          String?  @map("qr_code_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  
  // Relations
  games         Game[]
  rewards       Reward[]
  gameLogs      GameLog[]
  coupons       Coupon[]
  favorites     Favorite[]
  crmMessages   CRMMessage[]
  
  @@map("stores")
}

// Game Model - Game Configuration per Store
model Game {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  gameType  GameType @map("game_type")
  isActive  Boolean  @default(true) @map("is_active")
  config    Json?    // Game-specific configuration (difficulty, images, etc.)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rewards   Reward[]
  gameLogs  GameLog[]
  
  @@map("games")
}

// Reward Model - Game-Specific Rewards
model Reward {
  id           String   @id @default(uuid())
  storeId      String   @map("store_id")
  gameId       String   @map("game_id")
  targetScore  Int      @map("target_score")
  rewardName   String   @map("reward_name")
  rewardImage  String?  @map("reward_image")
  probability  Int      @default(100) // 0-100 percentage
  createdAt    DateTime @default(now()) @map("created_at")
  
  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  game  Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@map("rewards")
}

// GameLog Model - Game Play History
model GameLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id") // Nullable for non-authenticated plays
  storeId   String   @map("store_id")
  gameId    String   @map("game_id")
  gameType  GameType @map("game_type")
  score     Int
  playedAt  DateTime @default(now()) @map("played_at")
  
  // Relations
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  store Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  game  Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@map("game_logs")
}

// Coupon Model - Instant-Use Coupons
model Coupon {
  id          String       @id @default(uuid())
  code        String       @unique
  userId      String       @map("user_id")
  storeId     String       @map("store_id")
  rewardName  String       @map("reward_name")
  status      CouponStatus @default(ISSUED)
  issuedAt    DateTime     @default(now()) @map("issued_at")
  usedAt      DateTime?    @map("used_at")
  
  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@map("coupons")
}

// Favorite Model - Customer Favorites/Bookmarks
model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@unique([userId, storeId])
  @@map("favorites")
}

// CRMMessage Model - Push Message Storage
model CRMMessage {
  id          String            @id @default(uuid())
  storeId     String            @map("store_id")
  title       String
  content     String            @db.Text
  targetGroup CRMTargetGroup    @map("target_group")
  sentCount   Int               @default(0) @map("sent_count")
  sentAt      DateTime?         @map("sent_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  
  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@map("crm_messages")
}

// Enums
enum SubscriptionStatus {
  ACTIVE
  INACTIVE
}

enum GameType {
  PINBALL
  MATCH
  SPOT
}

enum CouponStatus {
  ISSUED
  USED
  EXPIRED
}

enum CRMTargetGroup {
  ALL
  VIP
  NEW
  AT_RISK
}
